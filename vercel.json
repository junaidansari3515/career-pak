{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/job-government",
      "destination": "/jobs-government",
      "permanent": true
    },
    {
      "source": "/job-government.html",
      "destination": "/jobs-government.html",
      "permanent": true
    },
    {
      "source": "/job-private",
      "destination": "/jobs-private",
      "permanent": true
    },
    {
      "source": "/job-private.html",
      "destination": "/jobs-private.html",
      "permanent": true
    },
    {
      "source": "/jobsgovernment",
      "destination": "/jobs-government",
      "permanent": true
    },
    {
      "source": "/jobsgovernment.html",
      "destination": "/jobs-government.html",
      "permanent": true
    },
    {
      "source": "/jobsprivate",
      "destination": "/jobs-private",
      "permanent": true
    },
    {
      "source": "/jobsprivate.html",
      "destination": "/jobs-private.html",
      "permanent": true
    }
  ]
}
